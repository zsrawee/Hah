# ═══════════════════════════════════════════════════════
# Hadith Project — Environment Variables
# ═══════════════════════════════════════════════════════

# --- Required (for speech analysis) ---

# At least one transcription API key is needed for server-side transcription.
# Get a free API key from:
#   HuggingFace: https://huggingface.co/settings/tokens
#   NVIDIA:      https://build.nvidia.com/explore/discover
#   OpenAI:      https://platform.openai.com/api-keys
#
# On Vercel free plan, you can skip these — the app will fall back
# to client-side transcription using the Web Speech API (free, no key).

# HUGGINGFACE_API_KEY=hf_...
# NVIDIA_API_KEY=nvapi-...
# OPENAI_API_KEY=sk-...

# --- Optional ---

# Base URL for the Hadith API (defaults to https://api.hadithapi.com)
# HADITH_API_BASE_URL=https://api.hadithapi.com

# Rate limiting (optional, used by default)
# Set to "false" to disable rate limiting in development
# RATE_LIMIT_ENABLED=true
